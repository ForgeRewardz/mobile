# Solana cluster: devnet | staging | mainnet-beta
SOLANA_CLUSTER=devnet

# RPC endpoint (defaults to public devnet if unset)
RPC_URL=https://api.devnet.solana.com

# Rewardz program ID (placeholder until deployed)
REWARDZ_PROGRAM_ID=11111111111111111111111111111111

# Token X SPL mint address
TOKEN_X_MINT=

# Intent API backend URL
INTENT_API_BASE_URL=http://localhost:3001

# Dialect Blink client API key (from dashboard.dialect.to)
BLINK_CLIENT_KEY=
