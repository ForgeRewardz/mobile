{
  "name": "rewardz-mobile",
  "scripts": {
    "android": "expo run:android",
    "android:build": "expo prebuild -p android",
    "build": "tsc --noEmit && npm run android:build",
    "ci": "tsc --noEmit && npm run lint:check && npm run format:check",
    "dev": "expo start --clear --dev-client --reset-cache",
    "doctor": "npx -y expo-doctor@latest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ios": "expo run:ios",
    "lint": "expo lint --fix",
    "lint:check": "expo lint",
    "start": "expo start",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web"
  },
  "displayName": "Rewardz Mobile",
  "description": "Solana-based reward infrastructure mobile app — discover rewarded on-chain actions, earn points, mint Token X.",
  "keywords": [
    "expo",
    "mobile-wallet-adapter",
    "react-native",
    "solana-kit",
    "rewardz",
    "blinks"
  ],
  "main": "./index.js",
  "version": "1.0.0",
  "dependencies": {
    "@dialectlabs/blinks-react-native": "^0.8.6",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo/metro-runtime": "~55.0.6",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@rewardz/sdk": "workspace:*",
    "@rewardz/types": "workspace:*",
    "@shopify/flash-list": "^2.3.1",
    "@solana-program/token": "^0.13.0",
    "@solana/kit": "^6.1.0",
    "@tanstack/react-query": "^5.96.2",
    "@wallet-ui/react-native-kit": "^4.0.1",
    "expo": "~55.0.8",
    "expo-blur": "^55.0.14",
    "expo-clipboard": "^55.0.13",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "^55.0.18",
    "expo-font": "^55.0.6",
    "expo-haptics": "^55.0.14",
    "expo-image": "^55.0.8",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-splash-screen": "^55.0.16",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "^55.0.14",
    "lottie-react-native": "^7.3.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.31.0",
    "react-native-quick-crypto": "^1.0.7",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "tailwindcss": "~4.1.16",
    "uniwind": "~1.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.14",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
